# Albert IA Agentic - Configuration
# Copiez ce fichier vers .env et remplissez les valeurs

# ====================
# SÉCURITÉ (OBLIGATOIRE)
# ====================

# Clé API Albert - OBTENIR SUR https://albert.api.etalab.gouv.fr
ALBERT_API_KEY=votre_cle_api_ici

# Token d'accès pour l'interface web (générer un token sécurisé)
# Générer avec: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
BOT_ACCESS_TOKEN=generer_un_token_securise_ici

# ====================
# SERVEUR
# ====================

HOST=0.0.0.0
PORT=8090
DEBUG=false

# ====================
# WORKSPACE
# ====================

WORKSPACE_ROOT=./workspace
OUTPUT_DIR=./workspace/output
TOOLS_DIR=./tools

# ====================
# LIMITES (SÉCURITÉ)
# ====================

# Timeout max pour les appels API (secondes)
API_TIMEOUT=120

# Timeout pour exécution Python (secondes)
PYTHON_EXEC_TIMEOUT=30

# Limite mémoire Python (Mo) - Linux only
PYTHON_MEMORY_LIMIT=256

# Rate limiting: requêtes par minute par IP
RATE_LIMIT_REQUESTS=30

# Taille max historique chat (messages)
MAX_CHAT_HISTORY=100
